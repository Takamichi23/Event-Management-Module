@page "/district-head/financial/monitoring"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@rendermode InteractiveServer

<PageTitle>Monitoring — District Head</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Financial Management</h1>
    <p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<!-- Tab Bar (5 tabs) -->
<div class="tab-bar">
    <a href="/district-head/financial/proposals" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Budget Proposals</a>
    <a href="/district-head/financial/transactions" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Transactions</a>
    <a href="/district-head/financial/allocation" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Budget Allocation</a>
    <a href="/district-head/financial/monitoring" class="tab active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Monitoring</a>
    <a href="/district-head/financial/reports" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Reports</a>
</div>

<!-- Ministry Budget Cards -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.25rem;">
    @foreach (var a in ministryAllocations)
    {
        var pct = a.Allocated > 0 ? (double)(a.Spent / a.Allocated) * 100 : 0;
        var barColor = pct > 75 ? "#c0392b" : pct > 50 ? "#e67e22" : "#27ae60";
        <div style="background:#fff;border:2px dashed #d1d9e6;border-radius:14px;padding:1.2rem 1.3rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.6rem;">
                <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin:0;">@a.Name</h3>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
                <span style="font-family:'Inter',sans-serif;font-size:0.75rem;color:#6b7c93;">Utilization</span>
                <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:700;color:#0d2137;">@(pct.ToString("F1"))%</span>
            </div>
            <div style="height:8px;background:#e8ecf1;border-radius:4px;overflow:hidden;margin-bottom:1rem;">
                <div style="height:100%;width:@(pct.ToString("F0"))%;background:@barColor;border-radius:4px;transition:width 0.4s;"></div>
            </div>
            <div style="display:flex;gap:2rem;margin-bottom:0.8rem;">
                <div>
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Allocated</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.1rem;color:#0d2137;">$@a.Allocated.ToString("N0")</span>
                </div>
                <div>
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Spent</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.1rem;color:#0d2137;">$@a.Spent.ToString("N0")</span>
                </div>
            </div>
            <div style="background:#f8fafc;border-radius:8px;padding:0.6rem 0.8rem;">
                <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Remaining Balance</span>
                <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;">$@a.RemainingBalance.ToString("N0")</span>
            </div>
        </div>
    }
</div>

<!-- Operations Budget Cards -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.25rem;">
    @foreach (var a in operationsAllocations)
    {
        var pct = a.Allocated > 0 ? (double)(a.Spent / a.Allocated) * 100 : 0;
        var barColor = pct > 75 ? "#c0392b" : pct > 50 ? "#e67e22" : "#27ae60";
        <div style="background:#fff;border:1.5px solid #e8ecf1;border-radius:14px;padding:1.2rem 1.3rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.6rem;">
                <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin:0;">@a.Name</h3>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
                <span style="font-family:'Inter',sans-serif;font-size:0.75rem;color:#6b7c93;">Utilization</span>
                <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:700;color:#0d2137;">@(pct.ToString("F1"))%</span>
            </div>
            <div style="height:8px;background:#e8ecf1;border-radius:4px;overflow:hidden;margin-bottom:1rem;">
                <div style="height:100%;width:@(pct.ToString("F0"))%;background:@barColor;border-radius:4px;transition:width 0.4s;"></div>
            </div>
            <div style="display:flex;gap:2rem;margin-bottom:0.8rem;">
                <div>
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Allocated</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.1rem;color:#0d2137;">$@a.Allocated.ToString("N0")</span>
                </div>
                <div>
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Spent</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.1rem;color:#0d2137;">$@a.Spent.ToString("N0")</span>
                </div>
            </div>
            <div style="background:#f8fafc;border-radius:8px;padding:0.6rem 0.8rem;">
                <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.05em;">Remaining Balance</span>
                <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;">$@a.RemainingBalance.ToString("N0")</span>
            </div>
        </div>
    }
</div>

<!-- System Alerts -->
<div style="background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:1.2rem;">
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e67e22" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin:0;">System Alerts</h3>
    </div>
    @if (alerts.Any())
    {
        @foreach (var alert in alerts)
        {
            <div style="display:flex;align-items:center;gap:0.5rem;padding:0.6rem 0.8rem;background:@alert.BgColor;border:1px solid @alert.BorderColor;border-radius:8px;margin-bottom:0.4rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="@alert.IconColor" stroke-width="2">
                    @if (alert.Type == "warning")
                    {
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    }
                    else
                    {
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    }
                </svg>
                <span style="font-family:'Inter',sans-serif;font-size:0.82rem;color:@alert.TextColor;">@alert.Message</span>
            </div>
        }
    }
    else
    {
        <div style="display:flex;align-items:center;gap:0.5rem;padding:0.6rem 0.8rem;background:#eafaf1;border:1px solid #a9dfbf;border-radius:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span style="font-family:'Inter',sans-serif;font-size:0.82rem;color:#1e5631;">All budgets are operating within healthy parameters.</span>
        </div>
    }
</div>

@code {
    private List<BudgetAllocation> allAllocations = new();

    protected override async Task OnInitializedAsync()
    {
        allAllocations = await Db.BudgetAllocations
            .OrderBy(a => a.Category).ThenBy(a => a.Name)
            .ToListAsync();
    }

    private List<BudgetAllocation> ministryAllocations => allAllocations.Where(a => a.Category == "Ministry").ToList();
    private List<BudgetAllocation> operationsAllocations => allAllocations.Where(a => a.Category == "Operations").ToList();

    private List<AlertItem> alerts
    {
        get
        {
            var items = new List<AlertItem>();
            foreach (var a in allAllocations)
            {
                if (a.Utilization > 90)
                    items.Add(new AlertItem { Type = "warning", Message = $"{a.Name} has exceeded 90% utilization ({a.Utilization:F0}%)", BgColor = "#fdedec", BorderColor = "#f5b7b1", IconColor = "#c0392b", TextColor = "#922b21" });
                else if (a.Utilization > 75)
                    items.Add(new AlertItem { Type = "warning", Message = $"{a.Name} utilization is at {a.Utilization:F0}% — approaching budget limit.", BgColor = "#fef9e7", BorderColor = "#f9e79f", IconColor = "#e67e22", TextColor = "#7d6608" });
            }
            return items;
        }
    }

    private class AlertItem
    {
        public string Type { get; set; } = "ok";
        public string Message { get; set; } = "";
        public string BgColor { get; set; } = "#eafaf1";
        public string BorderColor { get; set; } = "#a9dfbf";
        public string IconColor { get; set; } = "#27ae60";
        public string TextColor { get; set; } = "#1e5631";
    }
}
