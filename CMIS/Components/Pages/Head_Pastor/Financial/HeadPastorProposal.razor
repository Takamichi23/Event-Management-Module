@page "/head-pastor/financial/proposals"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Models
@using CMIS.Services
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Budget Proposals — Head Pastor</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Financial Management</h1>
    <p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<!-- Tab Bar (5 tabs for Head Pastor) -->
<div class="tab-bar">
    <a href="/head-pastor/financial/proposals" class="tab active">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Budget Proposals
    </a>
    <a href="/head-pastor/financial/transactions" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Transactions
    </a>
    <a href="/head-pastor/financial/allocation" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Budget Allocation
    </a>
    <a href="/head-pastor/financial/monitoring" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Monitoring
    </a>
    <a href="/head-pastor/financial/reports" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Reports
    </a>
</div>

<!-- Authority Banners -->
<div style="background:linear-gradient(135deg,#fef9e7,#fdebd0);border:1px solid #f0d9a0;border-radius:10px;padding:0.75rem 1rem;margin-bottom:0.6rem;display:flex;align-items:center;gap:0.5rem;">
    <span style="font-size:1rem;">⭐</span>
    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#5d4e37;">
        Your authority: Create <b style="background:#e8f4f8;padding:0.1rem 0.4rem;border-radius:3px;color:#1a5276;">Local Church</b> budget proposals and submit them to <b style="background:#fdebd0;padding:0.1rem 0.4rem;border-radius:3px;color:#7d6608;">Leadership Council</b> for approval.
    </span>
</div>
<div style="background:linear-gradient(135deg,#eafaf1,#d5f5e3);border:1px solid #a9dfbf;border-radius:10px;padding:0.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#1e5631;">
        Approver authority: You approve Ministry-level proposals from Ministry Heads.
    </span>
</div>

<!-- Sub-tabs -->
<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
    <button @onclick='() => activeSubTab = "my"' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "my" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "my" ? "#0d2137" : "#fff");color:@(activeSubTab == "my" ? "#fff" : "#6b7c93");transition:all 0.2s;">
        ⭐ My Proposals
        <span style="background:@(activeSubTab == "my" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.4rem;border-radius:10px;font-size:0.68rem;">@myProposals.Count</span>
    </button>
    <button @onclick='() => activeSubTab = "inbox"' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "inbox" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "inbox" ? "#0d2137" : "#fff");color:@(activeSubTab == "inbox" ? "#fff" : "#6b7c93");transition:all 0.2s;">
        📥 Approval Inbox
        <span style="background:@(activeSubTab == "inbox" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.4rem;border-radius:10px;font-size:0.68rem;">@inboxProposals.Count</span>
    </button>
    <button @onclick='() => activeSubTab = "all"' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "all" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "all" ? "#0d2137" : "#fff");color:@(activeSubTab == "all" ? "#fff" : "#6b7c93");transition:all 0.2s;">
        ⊙ All Proposals
        <span style="background:@(activeSubTab == "all" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.4rem;border-radius:10px;font-size:0.68rem;">@allProposals.Count</span>
    </button>
</div>

<!-- Toolbar -->
<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search proposals..." @bind="searchQuery" @bind:event="oninput" style="border:none;outline:none;background:none;font-family:'Inter',sans-serif;font-size:0.84rem;color:#1a1a2e;width:100%;" />
    </div>
    <select @bind="statusFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;">
        <option value="">All Statuses</option>
        <option value="Pending">Pending</option>
        <option value="Approved">Approved</option>
        <option value="Disapproved">Disapproved</option>
    </select>
    @if (activeSubTab == "inbox" || activeSubTab == "all")
    {
        <select @bind="ministryFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:140px;">
            <option value="0">All Ministries</option>
            @foreach (var m in ministries)
            {
                <option value="@m.MinistryId">@m.MinistryName</option>
            }
        </select>
    }
    <button @onclick="OpenModal" style="display:inline-flex;align-items:center;gap:0.4rem;margin-left:auto;padding:0.6rem 1.2rem;font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;">
        + New Local Church Proposal
    </button>
</div>

<!-- Data Table -->
<div style="background:#fff;border-radius:12px;border:1px solid #e8ecf1;overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;table-layout:fixed;">
        <colgroup><col style="width:12%"/><col style="width:24%"/><col style="width:12%"/><col style="width:12%"/><col style="width:16%"/><col style="width:14%"/><col style="width:10%"/></colgroup>
        <thead style="background:#f8fafc;">
            <tr>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;letter-spacing:0.04em;border-bottom:1px solid #e8ecf1;">ID</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Purpose</th>
                @if (activeSubTab != "all")
                {
                    <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">@(activeSubTab == "inbox" ? "Ministry" : "Church")</th>
                }
                @if (activeSubTab == "all")
                {
                    <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Ministry</th>
                }
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Amount</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Submission</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Status</th>
                <th style="padding:0.75rem 1rem;text-align:center;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in displayedProposals)
            {
                var statusColor = p.Status == "Approved" ? "#27ae60" : p.Status == "Disapproved" ? "#c0392b" : "#e67e22";
                var statusBg = p.Status == "Approved" ? "#eafaf1" : p.Status == "Disapproved" ? "#fdedec" : "#fef9e7";
                var levelBg = "#e8f4f8";
                var levelColor = "#1a5276";
                var submissionLabel = p.Level == "Local Church" ? "Head Pastor" : "Ministry Head";
                var approverLabel = p.Level == "Local Church" ? "Leadership Council" : "Head Pastor";
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">@p.ProposalCode</td>
                    <td style="padding:0.85rem 1rem;">
                        <span style="font-weight:600;color:#0d2137;display:block;">@p.Purpose</span>
                        <span style="font-size:0.72rem;color:#8e99a4;display:block;">@p.Ministry?.MinistryName</span>
                    </td>
                    @if (activeSubTab != "all")
                    {
                        <td style="padding:0.85rem 1rem;">
                            <span style="padding:0.2rem 0.5rem;border-radius:4px;font-size:0.7rem;font-weight:700;background:@levelBg;color:@levelColor;">
                                @(activeSubTab == "inbox" ? p.Ministry?.MinistryName : p.Church?.ChurchName ?? "—")
                            </span>
                        </td>
                    }
                    @if (activeSubTab == "all")
                    {
                        <td style="padding:0.85rem 1rem;">
                            <span style="padding:0.2rem 0.5rem;border-radius:4px;font-size:0.7rem;font-weight:700;background:#e8f4f8;color:#1a5276;">
                                @(p.Ministry?.MinistryName ?? "—")
                            </span>
                        </td>
                    }
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">$@p.Amount.ToString("N0")</td>
                    <td style="padding:0.85rem 1rem;">
                        <span style="display:block;font-size:0.78rem;color:#2c3e50;">@submissionLabel</span>
                        <span style="display:block;font-size:0.68rem;color:#8e99a4;">→ @approverLabel</span>
                    </td>
                    <td style="padding:0.85rem 1rem;">
                        <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.2rem 0.6rem;border-radius:12px;font-size:0.72rem;font-weight:600;background:@statusBg;color:@statusColor;">
                            <span style="width:6px;height:6px;border-radius:50%;background:@statusColor;display:inline-block;"></span>
                            @p.Status
                        </span>
                    </td>
                    <td style="padding:0.85rem 1rem;text-align:center;">
                        <svg @onclick="() => OpenViewModal(p)" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2" style="cursor:pointer;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showModal)
{
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;box-shadow:0 20px 60px rgba(13,33,55,0.25);display:flex;flex-direction:column;gap:1.1rem;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">New Local Church Proposal</h2>

            <div style="display:flex;flex-direction:column;gap:0.35rem;">
                <label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Purpose</label>
                <input type="text" @bind="newPurpose" placeholder="Brief purpose of this proposal"
                       style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;width:100%;box-sizing:border-box;" />
            </div>

            <div style="display:flex;flex-direction:column;gap:0.35rem;">
                <label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Description (Optional)</label>
                <textarea @bind="newDescription" rows="3" placeholder="Additional details..."
                          style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;resize:vertical;min-height:72px;width:100%;box-sizing:border-box;"></textarea>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.35rem;">
                    <label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Church</label>
                    <div style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;color:#1a5276;background:#f0f4f8;border:1.5px solid #d1d9e6;border-radius:8px;">@currentChurchName</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.35rem;">
                    <label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Level</label>
                    <div style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;color:#1a5276;background:#f0f4f8;border:1.5px solid #d1d9e6;border-radius:8px;">Local Church</div>
                </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:0.35rem;">
                <label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Amount ($)</label>
                <input type="number" @bind="newAmount" step="0.01" min="0" placeholder="0.00"
                       style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;width:100%;box-sizing:border-box;" />
            </div>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#c0392b;margin:0;">@modalError</p>
            }

            <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.25rem;">
                <button @onclick="CloseModal" style="padding:0.65rem 1.4rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                <button @onclick="SaveProposal" disabled="@isSaving" style="padding:0.65rem 1.5rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;opacity:@(isSaving ? "0.6" : "1");">@(isSaving ? "Submitting..." : "Submit Proposal")</button>
            </div>
        </div>
    </div>
}

@if (showViewModal && viewProposal != null)
{
    var sBg = viewProposal.Status == "Approved" ? "#eafaf1" : viewProposal.Status == "Disapproved" ? "#fdedec" : viewProposal.Status == "For Revision" ? "#e8f4f8" : "#fef9e7";
    var sColor = viewProposal.Status == "Approved" ? "#1e8449" : viewProposal.Status == "Disapproved" ? "#c0392b" : viewProposal.Status == "For Revision" ? "#1a5276" : "#b7950b";
    var sDot = viewProposal.Status == "Approved" ? "#27ae60" : viewProposal.Status == "Disapproved" ? "#e74c3c" : viewProposal.Status == "For Revision" ? "#2980b9" : "#d4ac0d";
    var canAct = viewProposal.Status == "Pending" && viewProposal.Level == "Ministry";
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseViewModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;box-shadow:0 20px 60px rgba(13,33,55,0.25);display:flex;flex-direction:column;gap:1.1rem;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">Proposal Details</h2>
                <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.3rem 0.7rem;border-radius:20px;font-size:0.75rem;font-weight:600;background:@sBg;color:@sColor;">
                    <span style="width:7px;height:7px;border-radius:50%;background:@sDot;display:inline-block;"></span>
                    @viewProposal.Status
                </span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Proposal ID</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#0d2137;font-weight:600;">@viewProposal.ProposalCode</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Level</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.Level</div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.3rem;">
                <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Purpose</span>
                <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.Purpose</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(viewProposal.Description))
            {
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Description</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;white-space:pre-wrap;">@viewProposal.Description</div>
                </div>
            }
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">From</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@GetFromLabel(viewProposal)</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Amount</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#0d2137;font-weight:600;">$@viewProposal.Amount.ToString("N2")</div>
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Submitted By</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@(viewProposal.SubmittedBy?.FirstName + " " + viewProposal.SubmittedBy?.LastName)</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Date Submitted</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.CreatedAt.ToString("MMM d, yyyy")</div>
                </div>
            </div>
            @if (viewProposal.Status == "Disapproved" || viewProposal.Status == "For Revision")
            {
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">@(viewProposal.Status == "Disapproved" ? "Rejection Reason" : "Revision Notes")</span>
                    <div style="padding:0.55rem 0.8rem;background:#fdf5f5;border:1.5px solid #f0d0d0;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;white-space:pre-wrap;">@(viewProposal.RejectionReason ?? "—")</div>
                </div>
            }
            @if (actionMode != "")
            {
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">@(actionMode == "reject" ? "Rejection Reason" : "Revision Notes") *</span>
                    <textarea @bind="actionReason" rows="3" placeholder="@(actionMode == "reject" ? "State reason for rejection..." : "Describe what needs to be revised...")" style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;resize:vertical;min-height:72px;width:100%;box-sizing:border-box;"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(actionError))
                {
                    <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#c0392b;margin:0;">@actionError</p>
                }
            }
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.25rem;">
                <button @onclick="CloseViewModal" style="padding:0.65rem 1.4rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Close</button>
                @if (canAct && actionMode == "")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick='() => actionMode = "revise"' style="padding:0.65rem 1.1rem;font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:600;color:#1a5276;background:#e8f4f8;border:none;border-radius:8px;cursor:pointer;">Revise</button>
                        <button @onclick='() => actionMode = "reject"' style="padding:0.65rem 1.1rem;font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:600;color:#c0392b;background:#fdedec;border:none;border-radius:8px;cursor:pointer;">Reject</button>
                        <button @onclick="ApproveProposal" disabled="@isActioning" style="padding:0.65rem 1.1rem;font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:700;color:#fff;background:#27ae60;border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "..." : "Approve")</button>
                    </div>
                }
                @if (actionMode != "")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="CancelAction" style="padding:0.65rem 1.1rem;font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:600;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                        <button @onclick="ExecuteAction" disabled="@isActioning" style="padding:0.65rem 1.1rem;font-family:'Inter',sans-serif;font-size:0.85rem;font-weight:700;color:#fff;background:@(actionMode == "reject" ? "#c0392b" : "#1a5276");border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "..." : actionMode == "reject" ? "Confirm Reject" : "Send for Revision")</button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<BudgetProposal> allProposals = new();
    private List<Ministry> ministries = new();
    private string activeSubTab = "my";
    private string searchQuery = "";
    private string statusFilter = "";
    private int ministryFilter = 0;
    private int currentProfileId = 0;
    private int currentChurchId = 0;
    private int? currentDistrictId = null;
    private string currentChurchName = "";

    // New proposal modal
    private bool showModal = false;
    private bool isSaving = false;
    private string newPurpose = "";
    private string newDescription = "";
    private decimal newAmount = 0;
    private string modalError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var accountIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (accountIdClaim != null && int.TryParse(accountIdClaim.Value, out int accountId))
        {
            var account = await Db.Accounts
                .Include(a => a.Church)
                .FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentProfileId = account?.ProfileId ?? 0;
            currentChurchId = account?.ChurchId ?? 0;
            currentDistrictId = account?.Church?.DistrictId;
            currentChurchName = account?.Church?.ChurchName ?? "—";
        }

        await ReloadProposals();

        ministries = await Db.Set<Ministry>()
            .Where(m => m.Status == "Active")
            .OrderBy(m => m.MinistryName)
            .ToListAsync();
    }

    private void OpenModal()
    {
        newPurpose = ""; newDescription = ""; newAmount = 0; modalError = "";
        showModal = true;
    }
    private void CloseModal() { showModal = false; modalError = ""; }

    private async Task SaveProposal()
    {
        modalError = "";
        if (string.IsNullOrWhiteSpace(newPurpose)) { modalError = "Purpose is required."; return; }
        if (newAmount <= 0) { modalError = "Amount must be greater than zero."; return; }
        if (currentProfileId == 0) { modalError = "Unable to identify current user."; return; }

        isSaving = true;

        var lastCode = await Db.BudgetProposals
            .OrderByDescending(p => p.ProposalId)
            .Select(p => p.ProposalCode)
            .FirstOrDefaultAsync();
        int nextNum = 1001;
        if (lastCode != null && lastCode.StartsWith("BP-") && int.TryParse(lastCode[3..], out int parsed))
            nextNum = parsed + 1;

        Db.BudgetProposals.Add(new BudgetProposal
        {
            ProposalCode = $"BP-{nextNum}",
            Purpose = newPurpose.Trim(),
            Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim(),
            MinistryId = null,
            ChurchId = currentChurchId > 0 ? currentChurchId : null,
            DistrictId = currentDistrictId,
            Level = "Local Church",
            Amount = newAmount,
            Status = "Pending",
            SubmittedById = currentProfileId,
            CreatedAt = DateTime.UtcNow
        });
        await Db.SaveChangesAsync();
        await ReloadProposals();
        isSaving = false;
        showModal = false;
    }

    private bool showViewModal = false;
    private BudgetProposal? viewProposal = null;
    private bool isActioning = false;
    private string actionMode = "";
    private string actionReason = "";
    private string actionError = "";

    private void OpenViewModal(BudgetProposal p)
    {
        viewProposal = p; showViewModal = true;
        actionMode = ""; actionReason = ""; actionError = "";
    }
    private void CloseViewModal()
    {
        showViewModal = false; viewProposal = null;
        actionMode = ""; actionReason = ""; actionError = "";
    }
    private void CancelAction() { actionMode = ""; actionReason = ""; actionError = ""; }

    private async Task ApproveProposal()
    {
        if (viewProposal == null) return;
        isActioning = true;
        var p = await Db.BudgetProposals.FindAsync(viewProposal.ProposalId);
        if (p != null) { p.Status = "Approved"; p.UpdatedAt = DateTime.UtcNow; await Db.SaveChangesAsync(); }
        await ReloadProposals();
        showViewModal = false; viewProposal = null; isActioning = false;
    }

    private async Task ExecuteAction()
    {
        if (viewProposal == null) return;
        if (string.IsNullOrWhiteSpace(actionReason)) { actionError = "Please provide a reason."; return; }
        isActioning = true; actionError = "";
        var p = await Db.BudgetProposals.FindAsync(viewProposal.ProposalId);
        if (p != null)
        {
            p.Status = actionMode == "reject" ? "Disapproved" : "For Revision";
            p.RejectionReason = actionReason.Trim();
            p.UpdatedAt = DateTime.UtcNow;
            await Db.SaveChangesAsync();
        }
        await ReloadProposals();
        showViewModal = false; viewProposal = null;
        actionMode = ""; actionReason = ""; isActioning = false;
    }

    private async Task ReloadProposals()
    {
        allProposals = await Db.BudgetProposals
            .Include(p => p.Ministry).Include(p => p.Church)
            .Include(p => p.District).Include(p => p.SubmittedBy)
            .OrderByDescending(p => p.CreatedAt).ToListAsync();
    }

    private string GetFromLabel(BudgetProposal p) =>
        p.Level == "District" ? p.District?.DistrictName ?? "—" :
        p.Level == "Local Church" ? p.Church?.ChurchName ?? "—" :
        p.Ministry?.MinistryName ?? "—";

    private List<BudgetProposal> myProposals => allProposals.Where(p => p.Level == "Local Church").ToList();
    private List<BudgetProposal> inboxProposals => allProposals.Where(p => p.Level == "Ministry" && p.Status == "Pending").ToList();

    private List<BudgetProposal> displayedProposals
    {
        get
        {
            var source = activeSubTab switch
            {
                "my" => myProposals,
                "inbox" => inboxProposals,
                _ => allProposals.Where(p => p.Level == "Ministry").ToList()
            };

            var q = source.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(p => p.Purpose.ToLower().Contains(s) || p.ProposalCode.ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(statusFilter))
                q = q.Where(p => p.Status == statusFilter);
            if (ministryFilter > 0 && (activeSubTab == "inbox" || activeSubTab == "all"))
                q = q.Where(p => p.MinistryId == ministryFilter);

            return q.ToList();
        }
    }
}
